{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://registry.semrel.io/schemas/plugins/slack/latest.json",
  "title": "semrel plugin args: slack",
  "description": "Posts a release announcement to a Slack channel via Incoming Webhook.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "webhook_url": {
      "type": "string",
      "description": "Slack Incoming Webhook URL."
    },
    "channel": {
      "type": "string",
      "description": "Target channel (e.g. `#releases`)."
    },
    "username": {
      "type": "string",
      "description": "Bot display name.",
      "default": "semrel"
    },
    "icon_emoji": {
      "type": "string",
      "description": "Emoji icon for the bot message.",
      "default": ":rocket:"
    },
    "max_retries": {
      "type": "string",
      "description": "Maximum retry attempts on transient failures.",
      "default": "3"
    },
    "retry_delay": {
      "type": "string",
      "description": "Delay between retries (Go duration string).",
      "default": "2s"
    }
  },
  "required": [
    "webhook_url"
  ]
}

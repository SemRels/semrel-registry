{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://registry.semrel.io/schemas/plugins/teams/v1.json",
  "title": "semrel plugin args: teams",
  "description": "Sends a release notification to a Microsoft Teams channel via Incoming Webhook.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "webhook_url": {
      "type": "string",
      "description": "Teams Incoming Webhook URL."
    },
    "title": {
      "type": "string",
      "description": "Card title.",
      "default": "\ud83d\ude80 New Release"
    },
    "theme_color": {
      "type": "string",
      "description": "Card accent color (hex, no leading #).",
      "default": "0078D7"
    },
    "mention": {
      "type": "string",
      "description": "Teams user email to @mention."
    },
    "max_retries": {
      "type": "string",
      "description": "Retry count on transient failures.",
      "default": "3"
    }
  },
  "required": [
    "webhook_url"
  ]
}

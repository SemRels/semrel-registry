PORT=:8080
DATABASE_URL=postgres://dev:dev@localhost:5432/semrel_registry?sslmode=disable
MIGRATE_DIR=./database/migrations
ENVIRONMENT=dev
ADMIN_TOKEN=dev-secret
# GitHub OAuth (register at https://github.com/settings/developers)
# Callback URL: http://localhost:8080/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
JWT_SECRET=change-me-in-production

# Comma-separated GitHub org(s) whose members get admin access
ALLOWED_GITHUB_ORGS=SemRels
# Or individual logins (comma-separated)
ADMIN_GITHUB_USERS=

# Where to redirect after successful OAuth (the admin frontend URL)
FRONTEND_URL=http://localhost:5173

PORT=:8080
DATABASE_URL=postgres://dev:dev@localhost:5432/semrel_registry?sslmode=disable
MIGRATE_DIR=./database/migrations
ENVIRONMENT=dev
ADMIN_TOKEN=dev-secret
# GitHub OAuth (register at https://github.com/settings/developers)
# Callback URL: http://localhost:8080/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
JWT_SECRET=change-me-in-production

# Comma-separated GitHub org(s) whose members get admin access
ALLOWED_GITHUB_ORGS=SemRels
# Or individual logins (comma-separated)
ADMIN_GITHUB_USERS=

# Where to redirect after successful OAuth (the admin frontend URL)
FRONTEND_URL=http://localhost:5173

# GitHub Personal Access Token for fetching releases & validating plugins (public repos only need no auth)
# With token: 5000 req/hr; without: 60 req/hr
GITHUB_TOKEN=

# Shared secret for the /api/v1/webhooks/release endpoint
# Set the same value as REGISTRY_SYNC_WEBHOOK_SECRET in each plugin repo's GitHub secrets
WEBHOOK_SECRET=

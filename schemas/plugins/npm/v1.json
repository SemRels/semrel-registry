{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://registry.semrel.io/schemas/plugins/npm/v1.json",
  "title": "semrel plugin args: npm",
  "description": "Updates the `version` field in package.json.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "file": {
      "type": "string",
      "description": "Path to the package manifest.",
      "default": "package.json"
    },
    "update_lockfile": {
      "type": "string",
      "description": "Run `npm install --package-lock-only` after update.",
      "default": "false",
      "enum": [
        "true",
        "false"
      ]
    }
  }
}

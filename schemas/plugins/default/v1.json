{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://registry.semrel.io/schemas/plugins/default/v1.json",
  "title": "semrel plugin args: default",
  "description": "Matches commit messages against configurable regex patterns to determine the SemVer bump level.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "major_patterns": {
      "type": "string",
      "description": "Comma-separated regexes for major bumps.",
      "default": "BREAKING CHANGE,feat!"
    },
    "minor_patterns": {
      "type": "string",
      "description": "Comma-separated regexes for minor bumps."
    },
    "patch_patterns": {
      "type": "string",
      "description": "Comma-separated regexes for patch bumps."
    }
  }
}

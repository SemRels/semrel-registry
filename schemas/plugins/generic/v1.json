{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://registry.semrel.io/schemas/plugins/generic/v1.json",
  "title": "semrel plugin args: generic",
  "description": "Runs one or more shell commands as a custom release gate.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "command": {
      "type": "string",
      "description": "Newline-separated shell commands. All must exit 0 for the condition to pass."
    },
    "env_var": {
      "type": "string",
      "description": "(Legacy) Environment variable name to compare."
    },
    "env_value": {
      "type": "string",
      "description": "(Legacy) Expected value for env_var."
    }
  }
}

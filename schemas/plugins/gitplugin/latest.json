{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://registry.semrel.io/schemas/plugins/gitplugin/latest.json",
  "title": "semrel plugin args: gitplugin",
  "description": "Pushes the release tag or a changelog commit to a secondary git repository.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "repo": {
      "type": "string",
      "description": "Target git repository URL."
    },
    "branch": {
      "type": "string",
      "description": "Branch to update.",
      "default": "main"
    },
    "token": {
      "type": "string",
      "description": "Authentication token for the target repository."
    }
  },
  "required": [
    "repo"
  ]
}

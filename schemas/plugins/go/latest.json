{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://registry.semrel.io/schemas/plugins/go/latest.json",
  "title": "semrel plugin args: go",
  "description": "Updates a version variable in a Go source file.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "file": {
      "type": "string",
      "description": "Path to the Go source file containing the version variable.",
      "default": "version.go"
    },
    "variable": {
      "type": "string",
      "description": "Go variable name to update.",
      "default": "Version"
    }
  }
}

# semrel Registry — environment configuration
# Copy to .env and fill in your values.
# This file is read by the Go API and should be placed in the project root.

# Go API
PORT=:8080
MIGRATE_DIR=./api/database/migrations
ENVIRONMENT=dev   # dev | prod

# PostgreSQL (matches docker-compose.yml)
DATABASE_URL=postgres://dev:dev@localhost:5433/semrel_registry?sslmode=disable

# Admin fallback token (local dev only — use GitHub OAuth in production)
ADMIN_TOKEN=dev-secret

# GitHub OAuth App (https://github.com/settings/developers)
# Callback URL: http://localhost:8080/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
JWT_SECRET=change-me-in-production

# Org owners of these GitHub orgs get admin access to the registry
ALLOWED_GITHUB_ORGS=SemRels
# Or whitelist individual GitHub logins
ADMIN_GITHUB_USERS=

# URL the Go API redirects to after GitHub OAuth (the admin panel)
FRONTEND_URL=http://localhost:5173/oauth/callback

# GitHub Personal Access Token — raises rate limit from 60 to 5000 req/hr
# Required for version autoloading (POST /api/v1/admin/sync-versions)
GITHUB_TOKEN=

# Webhook secret shared with plugin repo secrets (REGISTRY_SYNC_WEBHOOK_SECRET)
# Secures POST /api/v1/webhooks/release
WEBHOOK_SECRET=

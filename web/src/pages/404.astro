---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page not found | registry.semrel.io" description="The requested registry page could not be found.">
  <div class="container">
    <section class="section hero">
      <p class="section-kicker">404</p>
      <h1>Page not found</h1>
      <p>The page you requested does not exist. Head back to the plugin directory or continue with the registry documentation.</p>
      <div class="hero__actions">
        <a class="button button--primary" href="/plugins/">Browse Plugins</a>
        <a class="button button--ghost" href="/docs/">Open Docs</a>
      </div>
    </section>
  </div>
</Layout>

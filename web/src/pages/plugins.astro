---
import FilterTags from '../components/FilterTags.astro';
import PluginCard from '../components/PluginCard.astro';
import Layout from '../layouts/Layout.astro';
import { getCategories, loadRegistry } from '../lib/registry';

const registry = loadRegistry();
const plugins  = [...registry.plugins].sort((a, b) => a.name.localeCompare(b.name));
const categories = getCategories(plugins);
---

<Layout title="Plugins · registry.semrel.io" description="Browse go-semrel plugins.">
  <div class="container">

    <div class="hero">
      <h1>Plugin Directory</h1>
      <p>Browse {plugins.length} verified go-semrel plugins.</p>
    </div>

    <div class="control-bar" data-plugin-directory>
      <input
        class="search-input"
        id="plugin-search"
        type="search"
        placeholder="Search by name, author, tag…"
        autocomplete="off"
        data-plugin-search
      />
      <FilterTags categories={categories} />
    </div>

    <p class="results-meta" aria-live="polite">
      <span data-results-count>{plugins.length}</span> plugin{plugins.length === 1 ? '' : 's'}
      &ensp;·&ensp;<a href="/plugins.json">raw JSON</a>
    </p>

    {plugins.length > 0 ? (
      <div class="plugin-list" data-plugin-list>
        {plugins.map((plugin) => <PluginCard plugin={plugin} />)}
      </div>
    ) : (
      <div class="empty-state" data-empty-state>
        <h2>No plugins published yet</h2>
        <p>Cards render automatically once metadata lands in plugins.json.</p>
      </div>
    )}

    <div class="empty-state" data-filter-empty-state hidden style="margin-top:1rem">
      <h2>No plugins match the current filters</h2>
      <p>Try another search term or reset the filters.</p>
    </div>

  </div>

  <script is:inline>
    (() => {
      const searchInput   = document.querySelector('[data-plugin-search]');
      const cards         = [...document.querySelectorAll('[data-plugin-card]')];
      const catButtons    = [...document.querySelectorAll('[data-filter-category]')];
      const relButtons    = [...document.querySelectorAll('[data-filter-release]')];
      const countEl       = document.querySelector('[data-results-count]');
      const filterEmpty   = document.querySelector('[data-filter-empty-state]');
      let activeCategory  = 'all';
      let activeRelease   = 'all';

      const sync = (btns, key, val) =>
        btns.forEach(b => {
          const sel = b.dataset[key] === val;
          b.setAttribute('aria-pressed', String(sel));
          b.classList.toggle('is-selected', sel);
        });

      const filter = () => {
        const q = (searchInput instanceof HTMLInputElement ? searchInput.value : '').trim().toLowerCase();
        let n = 0;
        cards.forEach(c => {
          const hay = [c.dataset.name, c.dataset.author, c.dataset.category, c.dataset.tags].join(' ');
          const ok  = (!q || hay.includes(q))
                   && (activeCategory === 'all' || c.dataset.category === activeCategory)
                   && (activeRelease  === 'all' || c.dataset.releaseChannel === activeRelease);
          c.hidden = !ok;
          if (ok) n++;
        });
        if (countEl)    countEl.textContent = String(n);
        if (filterEmpty instanceof HTMLElement) filterEmpty.hidden = n !== 0;
      };

      if (searchInput instanceof HTMLInputElement) searchInput.addEventListener('input', filter);
      catButtons.forEach(b => b.addEventListener('click', () => { activeCategory = b.dataset.filterCategory || 'all'; sync(catButtons, 'filterCategory', activeCategory); filter(); }));
      relButtons.forEach(b => b.addEventListener('click', () => { activeRelease  = b.dataset.filterRelease  || 'all'; sync(relButtons,  'filterRelease',  activeRelease);  filter(); }));
      sync(catButtons, 'filterCategory', activeCategory);
      sync(relButtons,  'filterRelease',  activeRelease);
    })();
  </script>
</Layout>

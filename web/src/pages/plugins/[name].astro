---
import Layout from '../../layouts/Layout.astro';
import {
  fetchRegistry,
  formatReleaseDate,
  getCategoryLabel,
  getLatestVersion,
  getSortedVersions,
} from '../../lib/registry';

export async function getStaticPaths() {
  const registry = await fetchRegistry();
  return registry.plugins.map((plugin) => ({
    params: { name: plugin.name },
    props:  { plugin },
  }));
}

const { plugin }       = Astro.props;
const latest           = getLatestVersion(plugin);
const sortedVersions   = getSortedVersions(plugin);
const tags             = plugin.tags ?? [];
const catClass         = `badge badge--${plugin.category}`;
---

<Layout title={`${plugin.name} · registry.semrel.io`} description={plugin.description}>
  <div class="container">

    <p class="breadcrumb"><a href="/plugins/">← Plugins</a></p>

    <div class="plugin-detail__header">
      <div>
        <div class="plugin-detail__title-row">
          <h1>{plugin.name}</h1>
          <span class={catClass}>{getCategoryLabel(plugin.category)}</span>
        </div>
        <p class="plugin-detail__description">{plugin.description}</p>
        <div class="plugin-detail__meta">
          <span>by {plugin.author}</span>
          <span>{plugin.license}</span>
          {latest && <span>latest <code>v{latest.version}</code></span>}
        </div>
        {tags.length > 0 && (
          <ul class="tag-list">
            {tags.map(t => <li>{t}</li>)}
          </ul>
        )}
      </div>
      <div class="plugin-detail__actions">
        {plugin.repository && <a class="button" href={plugin.repository} target="_blank" rel="noopener">Repository ↗</a>}
        {latest?.downloadUrl && <a class="button" href={latest.downloadUrl} target="_blank" rel="noopener">Download ↗</a>}
      </div>
    </div>

    {latest && (
      <div class="section">
        <p class="section-title">Installation</p>
        <div class="install-grid">
          <div class="card">
            <h3>go install</h3>
            <pre><code>go install github.com/SemRels/{plugin.name}/cmd/plugin@latest</code></pre>
          </div>
          <div class="card">
            <h3>semrel.yaml</h3>
            <pre><code>{`plugins:\n  - name: ${plugin.name}`}</code></pre>
          </div>
        </div>
      </div>
    )}

    {sortedVersions.length > 0 && (
      <div class="section">
        <p class="section-title">Versions</p>
        <div class="card" style="padding:0;overflow:hidden">
          <table class="versions-table">
            <thead>
              <tr><th>Version</th><th>Released</th><th>Channel</th></tr>
            </thead>
            <tbody>
              {sortedVersions.map((v, i) => (
                <tr>
                  <td>
                    <span class="version-tag">v{v.version}</span>
                    {i === 0 && <span class="latest-badge">latest</span>}
                    {v.prerelease && <span class="pre-badge">pre</span>}
                  </td>
                  <td class="muted">{formatReleaseDate(v.releaseDate)}</td>
                  <td class="muted">{v.prerelease ? 'prerelease' : 'stable'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    )}

    {sortedVersions.length === 0 && (
      <div class="empty-state">
        <h2>No releases yet</h2>
        <p>Plugin is registered but no version has been published.</p>
        {plugin.repository && (
          <a class="button" href={`${plugin.repository}/releases`} target="_blank" rel="noopener" style="margin-top:0.75rem">
            Watch releases on GitHub ↗
          </a>
        )}
      </div>
    )}

  </div>
</Layout>

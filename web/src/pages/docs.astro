---
import Layout from '../layouts/Layout.astro';
import { loadRegistry } from '../lib/registry';

const registry = loadRegistry();
const releaseGuideUrl = 'https://github.com/GoSemantics/go-semrel-registry/blob/main/docs/release-guide.md';
const schemaUrl = 'https://github.com/GoSemantics/go-semrel-registry/blob/main/schemas/plugin-metadata.json';
const payloadExample = `{
  "schemaVersion": ${registry.schemaVersion},
  "generatedAt": "2026-05-24T12:00:00Z",
  "plugins": [
    {
      "name": "provider-github",
      "description": "GitHub provider plugin for go-semrel.",
      "author": "GoSemantics",
      "category": "provider",
      "tags": ["github", "releases"],
      "versions": [
        {
          "version": "0.1.0",
          "releaseDate": "2026-05-24T12:00:00Z",
          "downloadUrl": "https://github.com/GoSemantics/provider-github/releases/download/provider-github-v0.1.0/provider-github.tar.gz",
          "checksums": {
            "linux_amd64": "<sha256>",
            "linux_arm64": "<sha256>",
            "darwin_amd64": "<sha256>",
            "darwin_arm64": "<sha256>",
            "windows_amd64": "<sha256>",
            "windows_arm64": "<sha256>"
          },
          "compatibility": {
            "minSemrelVersion": "0.1.5",
            "gRPCVersion": "v1"
          },
          "prerelease": false
        }
      ]
    }
  ]
}`;
const configExample = `SEMREL_REGISTRY_URL=https://registry.semrel.io/plugins.json
SEMREL_PLUGIN_CACHE_DIR=.semrel/<GOOS>_<GOARCH>
SEMREL_ALLOW_PRERELEASE=false`;
---

<Layout title="Registry Documentation | registry.semrel.io" description="Reference documentation for the static go-semrel plugin registry.">
  <div class="container">
    <section class="section">
      <p class="section-kicker">Documentation</p>
      <h1 class="section-heading">API reference and integration guide</h1>
      <p class="section-copy">
        The registry currently ships as a static website plus a raw JSON endpoint. Use this page to understand the
        payload shape, expected install flow, local cache conventions, and common troubleshooting steps.
      </p>
    </section>

    <section class="docs-grid section">
      <article class="doc-card">
        <p class="section-kicker">API reference</p>
        <h2><code>plugins.json</code> schema</h2>
        <p>The source of truth is <a href="/plugins.json">/plugins.json</a>. The full JSON Schema lives in the repository.</p>
        <ul>
          <li><strong>schemaVersion</strong> — registry payload version for compatibility checks.</li>
          <li><strong>generatedAt</strong> — timestamp written by automation when the index is regenerated.</li>
          <li><strong>plugins[]</strong> — plugin records with discovery metadata and versioned releases.</li>
          <li><strong>versions[]</strong> — release date, download URL, checksum set, compatibility hints, and prerelease flag.</li>
        </ul>
        <pre><code>{payloadExample}</code></pre>
        <p><a href={schemaUrl}>Open the full schema on GitHub</a></p>
      </article>

      <article class="doc-card">
        <p class="section-kicker">Installation guide</p>
        <h2>How to consume the registry</h2>
        <ol>
          <li>Fetch <code>/plugins.json</code> and resolve the plugin you want by name or category.</li>
          <li>Pick the latest compatible release for your semrel version and platform.</li>
          <li>Download the asset from <code>downloadUrl</code> and verify the published SHA-256 checksum.</li>
          <li>Store the extracted binary under <code>.semrel/&lt;GOOS&gt;_&lt;GOARCH&gt;/&lt;plugin-name&gt;/&lt;version&gt;/</code>.</li>
        </ol>
        <p>Registry-aware clients will automate this flow later, but the static endpoint is already stable enough for scripts and CI pipelines.</p>
      </article>

      <article class="doc-card">
        <p class="section-kicker">Configuration</p>
        <h2>Environment variables and cache layout</h2>
        <p>The website itself has no runtime configuration. If you build client-side automation around the registry, keep these values configurable in CI:</p>
        <pre><code>{configExample}</code></pre>
        <ul>
          <li><strong>SEMREL_REGISTRY_URL</strong> — preferred endpoint for registry metadata.</li>
          <li><strong>SEMREL_PLUGIN_CACHE_DIR</strong> — local cache root for verified plugin binaries.</li>
          <li><strong>SEMREL_ALLOW_PRERELEASE</strong> — opt in to prerelease assets when your workflow needs them.</li>
        </ul>
      </article>

      <article class="doc-card">
        <p class="section-kicker">Troubleshooting</p>
        <h2>Common issues</h2>
        <ul>
          <li><strong>Plugin not listed</strong> — confirm the metadata PR was merged and <code>plugins.json</code> was regenerated.</li>
          <li><strong>Checksum mismatch</strong> — ensure you downloaded the exact asset referenced by <code>downloadUrl</code>.</li>
          <li><strong>Version rejected</strong> — compare <code>compatibility.minSemrelVersion</code> and <code>compatibility.gRPCVersion</code> against your runtime.</li>
          <li><strong>Empty directory page</strong> — the static site is functioning; it simply means no plugin metadata has been published yet.</li>
        </ul>
      </article>
    </section>

    <section class="section quick-links">
      <article class="card">
        <p class="section-kicker">Contributor help</p>
        <h2>Release submission guide</h2>
        <p class="section-copy">Need to publish a plugin? Start with the release guide for tag naming, checksum generation, and registry submission expectations.</p>
        <a class="button button--ghost" href={releaseGuideUrl}>Open release guide</a>
      </article>
      <article class="card">
        <p class="section-kicker">Future evolution</p>
        <h2>Designed for a later API upgrade</h2>
        <p class="section-copy">The MVP stays static and GitHub Pages friendly today, while the project leaves room for a dedicated API and admin panel in a future phase.</p>
      </article>
    </section>
  </div>
</Layout>

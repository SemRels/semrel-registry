---
import Layout from '../layouts/Layout.astro';
import { loadRegistry } from '../lib/registry';

const registry = loadRegistry();
const cats = Object.entries(
  registry.plugins.reduce((acc, p) => { acc[p.category] = (acc[p.category] || 0) + 1; return acc; }, {} as Record<string, number>)
).sort((a, b) => b[1] - a[1]);
---

<Layout title="semrel Registry">
  <div class="container">

    <div class="hero">
      <h1>go-semrel Plugin Registry</h1>
      <p>Discover, verify and install plugins for <a href="https://semrel.io">go-semrel</a> — a semantic versioning toolkit for Go.</p>
      <div class="hero__actions">
        <a class="button button--primary" href="/plugins/">Browse Plugins</a>
        <a class="button" href="/docs/">Documentation</a>
        <a class="button" href="/plugins.json">plugins.json</a>
      </div>
    </div>

    <div class="stat-grid">
      <div class="stat-card">
        <div class="stat-card__label">Total plugins</div>
        <div class="stat-card__value">{registry.plugins.length}</div>
      </div>
      {cats.map(([cat, count]) => (
        <div class="stat-card">
          <div class="stat-card__label">{cat}</div>
          <div class="stat-card__value">{count}</div>
        </div>
      ))}
    </div>

    <div class="section">
      <p class="section-title">Registry endpoints</p>
      <div class="card" style="display:grid;gap:0.5rem">
        {[
          ['GET', '/plugins.json',          'Full plugin index (static JSON)'],
          ['GET', '/api/v1/plugins',         'Plugin list (paginated, filterable)'],
          ['GET', '/api/v1/plugins/:id',     'Single plugin by ID or name'],
          ['GET', '/api/v1/plugins/:id/versions', 'Version list for a plugin'],
          ['GET', '/api/v1/stats',           'Aggregate stats by category'],
        ].map(([method, path, desc]) => (
          <div style="display:grid;grid-template-columns:3rem 14rem 1fr;gap:0.5rem;align-items:center;font-size:0.8125rem">
            <code style="color:var(--success);font-size:0.75rem">{method}</code>
            <code style="color:var(--accent)">{path}</code>
            <span style="color:var(--text-muted)">{desc}</span>
          </div>
        ))}
      </div>
    </div>

  </div>
</Layout>

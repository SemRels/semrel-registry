---
import type { PluginCategory } from '../lib/registry';
import { getCategoryLabel } from '../lib/registry';

interface Props { categories: PluginCategory[]; }
const { categories } = Astro.props;
---

<div class="filter-group" role="toolbar" aria-label="Filter by category">
  <button class="pill is-selected" type="button" data-filter-category="all" aria-pressed="true">All</button>
  {categories.map(c => (
    <button class="pill" type="button" data-filter-category={c} aria-pressed="false">
      {getCategoryLabel(c)}
    </button>
  ))}
</div>
<div class="filter-group" role="toolbar" aria-label="Filter by release channel" style="margin-left:0.5rem">
  <button class="pill is-selected" type="button" data-filter-release="all" aria-pressed="true">All</button>
  <button class="pill" type="button" data-filter-release="stable" aria-pressed="false">Stable</button>
  <button class="pill" type="button" data-filter-release="prerelease" aria-pressed="false">Pre</button>
</div>

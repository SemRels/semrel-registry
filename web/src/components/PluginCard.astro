---
import type { Plugin } from '../lib/registry';
import { getCategoryLabel, getLatestVersion } from '../lib/registry';

interface Props {
  plugin: Plugin;
}

const { plugin } = Astro.props;
const latest = getLatestVersion(plugin);
const tags   = (plugin.tags ?? []).join(' ').toLowerCase();
const catClass = `badge badge--${plugin.category}`;
---

<a
  class="plugin-row"
  href={`/plugins/${plugin.name}/`}
  data-plugin-card
  data-name={plugin.name.toLowerCase()}
  data-author={plugin.author.toLowerCase()}
  data-category={plugin.category}
  data-tags={tags}
  data-release-channel={latest?.prerelease ? 'prerelease' : 'stable'}
>
  <span class="plugin-row__name">{plugin.name}</span>
  <span class="plugin-row__desc">{plugin.description}</span>
  <span class="plugin-row__right">
    {latest && <code class="muted" style="font-size:0.75rem">v{latest.version}</code>}
    <span class={catClass}>{getCategoryLabel(plugin.category)}</span>
  </span>
</a>
